# Esther - offline preset for revision/compatibility (read-only mode)
# Skopiruy v .env ili eksportiruy v okruzhenie. Bezopasnye defolty.

# A/B fuse: A = play/read-only, B = allow writing to operational artifacts (glossy/basseline/alias)
AB_MODE=A

# Manifest source (if not on USB)
COMPAT_DEV_MANIFEST=/mnt/data/ester_manifest.json

# Portable / One-Click / Bootable
ONECLICK_ENABLE=1
USB_BOOTSTRAP_ENABLE=1
USB_BOOTSTRAP_POLL_SEC=20
PORTABLE_BOOTOPS_ALLOW=0
PORTABLE_BOOTOPS_LABEL=ESTER

# USB Job Runner / Catalog
USB_RUNNER_ENABLE=1
USB_RUNNER_MAX_JOBS=50
USB_RUNNER_TEMPLATES_ENABLE=1
USB_RUNNER_DEST_WHITELIST=~/.ester/imports
USB_CATALOG_ENABLE=1
USB_CATALOG_DEFAULT_DEST=~/.ester/imports

# LAN Catalog
LAN_CATALOG_ENABLE=1
LAN_CATALOG_GROUP=239.23.0.73
LAN_CATALOG_PORT=40730
LAN_CATALOG_ANNOUNCE_SEC=30
LAN_CATALOG_PULL_SEC=60
LAN_CATALOG_NODE_NAME=EsterNode
LAN_CATALOG_TAGS=usb,models
LAN_CATALOG_BASE_URL=http://127.0.0.1:8000

# Checklist / Diagnostics / State
PORTABLE_CHECKLIST_ENABLE=1
ESTER_STATE_DIR=~/.ester

# Zemnoy abzats:
# This preset includes only offline revision: reading the manifest/routes, checking the list/aliases and collecting KPI on the page
# /admin/portable/complianke. No network actions or system rights are required.

# Mosty:
#  - Explicit: a single set of ENV activates the Comp/Diagnostics and Portable tab.
#  - Hidden: A/V fuse, offline mode, safe destination paths.

# c=a+b
