# === CommsBridge / Messaging Adapters (primer) ===

# Local gateway to the Ester core (drop-in, compatible with chat_handler.po or similar)
ESTER_CHAT_GATEWAY=http://localhost:8099/ester/chat

# Maskirovka pod «cheloveka»
ESTER_MASK_HUMANLIKE=1

# Switch A/B implementation of HTTP client (safe fallback)
ESTER_MESSAGING_IMPL=A

# Enabling a feature in the main application
ESTER_FEATURE_MESSAGING=1

# --- Telegram ---
ESTER_TELEGRAM_BOT_TOKEN=123456:ABCDEF

# --- WhatsApp Cloud API ---
ESTER_WHATSAPP_PHONE_ID=000000000000000
ESTER_WHATSAPP_TOKEN=EAAG-PLACEHOLDER
ESTER_WHATSAPP_VERIFY_TOKEN=verify-me

# c=a+b
