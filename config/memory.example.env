# config/memory.example.env
# An example of Esther's memory settings.
# Doesn't break anything by default, all flags are soft.

# === Night sleep cycle ===
# A/B to implement the sleep cycle. Usually: A - stable slot.
ESTER_MEMORY_SLEEP_AB=A

# Enable additional checks/detailed sleep cycle log (0/1).
ESTER_MEMORY_SLEEP_QA=0

# Storage policy application mode (0/1).
ESTER_MEMORY_SLEEP_POLICY=1

# Delat rezervnoe logirovanie shagov sna (0/1).
ESTER_MEMORY_SLEEP_BACKUP=0

# Enable day reflection in the night cycle (0/1).
ESTER_MEMORY_REFLECT=1

# === Sloy opyta ===
# Include layers of experience in the nightly sleep cycle (0/1).
# 0 - sleep works without experience; 1 - after reflection, an experience profile is built.
ESTER_MEMORY_EXPERIENCE_IN_SLEEP=1

# A/B to implement the experience. A is the default stable branch.
ESTER_MEMORY_EXPERIENCE_AB=A

# Allow writing anchors (anchurs) from experience into long-term memory (0/1).
# 0 - read and count only; 1 — create anchor events through a common record_event.
ESTER_MEMORY_EXPERIENCE_WRITE=0
