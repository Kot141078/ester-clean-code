# config/memory.example.env
# Primer nastroek pamyati Ester.
# Nichego ne lomaet po umolchaniyu, vse flagi — myagkie.

# === Nochnoy tsikl sna ===
# A/B dlya realizatsii tsikla sna. Obychno: A — stabilnyy slot.
ESTER_MEMORY_SLEEP_AB=A

# Vklyuchit dopolnitelnye proverki/podrobnyy log tsikla sna (0/1).
ESTER_MEMORY_SLEEP_QA=0

# Rezhim primeneniya politik khraneniya (0/1).
ESTER_MEMORY_SLEEP_POLICY=1

# Delat rezervnoe logirovanie shagov sna (0/1).
ESTER_MEMORY_SLEEP_BACKUP=0

# Vklyuchit dnevnuyu refleksiyu v nochnom tsikle (0/1).
ESTER_MEMORY_REFLECT=1

# === Sloy opyta ===
# Vklyuchat sloy opyta v nochnom tsikle sna (0/1).
# 0 — son rabotaet bez opyta; 1 — posle refleksii stroitsya profil opyta.
ESTER_MEMORY_EXPERIENCE_IN_SLEEP=1

# A/B dlya realizatsii opyta. A — defoltnaya stabilnaya vetka.
ESTER_MEMORY_EXPERIENCE_AB=A

# Razreshit zapisi-yakorya (anchors) iz opyta v dolgovremennuyu pamyat (0/1).
# 0 — tolko chitat i schitat; 1 — sozdavat anchor-sobytiya cherez obschiy record_event.
ESTER_MEMORY_EXPERIENCE_WRITE=0
