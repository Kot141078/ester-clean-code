# ================== Ester Video Ingest — ENV presety (primer) ==================
# Bezopasnye defolty. Skopiruy/pereimenuy v .env ili vklyuchi v svoy konfig-menedzhment.
#
# A/B-sloty dlya ASR:
#   A — ispolzovat suschestvuyuschiy dvizhok modules.ingest.asr_engine.asr_transcribe (drop-in).
#   B — ispolzovat faster-whisper (esli ustanovlen). Pri oshibke — avto-otkat na A.
VIDEO_INGEST_AB=A

# Model dlya faster-whisper (B-slot): tiny/base/small/medium/large-v3 i t.p.
VIDEO_ASR_MODEL=medium

# Vklyuchit CUDA dlya faster-whisper (esli GPU dostupen).
USE_CUDA=1

# Proaktivnyy obkhod podpisok (pod kontrolem planirovschika/cron).
VIDEO_SUBS_ENABLED=0

# Primechanie: dlya YouTube/onlayn-istochnikov dolzhen byt dostupen internet i yt-dlp v PATH.
# Dlya oflayna — analiz lokalnykh faylov (mp4/mkv/m4a/…).

# Mosty:
# - Yavnyy: (Inzheneriya ↔ Ekspluatatsiya) predskazuemye pereklyuchateli povedeniya bez pravki koda.
# - Skrytyy #1: (Kibernetika ↔ Resursy) upravlenie ustroystvom (CPU/GPU) i slozhnostyu modeli.
# - Skrytyy #2: (Infoteoriya ↔ Nadezhnost) unifitsirovannye peremennye uproschayut diagnostiku i CI.

# Zemnoy abzats: eto «nastroyki stanka»: skorost rezaniya, tip reztsa, vklyuchena li turbina.

# c=a+b
