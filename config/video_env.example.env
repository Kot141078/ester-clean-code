# ================== Ester Video Ingest — ENV presety (primer) ==================
# Safe defaults. Copy/rename it to .env or include it in your config management.
#
# A/V slots for ACP:
#   A - use the existing engine modules.ingest.asr_engine.asr_transcribe (drop-in).
#   B — use the faster-upper (if installed). In case of an error, auto-rollback to A.
VIDEO_INGEST_AB=A

# Model dlya faster-whisper (B-slot): tiny/base/small/medium/large-v3 i t.p.
VIDEO_ASR_MODEL=medium

# Include HERE for faster-vnisper (if GPU is available).
USE_CUDA=1

# Proactive bypass of subscriptions (under scheduler/crown control).
VIDEO_SUBS_ENABLED=0

# Note: for YouTube/online sources, the Internet and from-dlp in PATH must be available.
# For offline - analysis of local files (mpch/mkv/m4a/...).

# Mosty:
# - Yavnyy: (Inzheneriya ↔ Ekspluatatsiya) predskazuemye pereklyuchateli povedeniya bez pravki koda.
# - Skrytyy #1: (Kibernetika ↔ Resursy) upravlenie ustroystvom (CPU/GPU) i slozhnostyu modeli.
# - Skrytyy #2: (Infoteoriya ↔ Nadezhnost) unifitsirovannye peremennye uproschayut diagnostiku i CI.

# Ground paragraph: these are the “machine settings”: cutting speed, cutter type, whether the turbine is on.

# c=a+b
