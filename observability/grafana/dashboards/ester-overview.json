{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "name": "Annotations & Alerts",
        "hide": true
      }
    ]
  },
  "panels": [
    {
      "type": "graph",
      "title": "HTTP Requests",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method, path, status)",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "graph",
      "title": "HTTP Errors",
      "targets": [
        {
          "expr": "sum(rate(http_errors_total[5m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      }
    },
    {
      "type": "graph",
      "title": "Latency p95",
      "targets": [
        {
          "expr": "job:http_request_latency_seconds:p95",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      }
    }
  ],
  "schemaVersion": 36,
  "title": "Ester Overview",
  "version": 1
}
