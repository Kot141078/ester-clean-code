#!/usr/bin/env python
# -*- coding: utf-8 -*-
"""
Ester pre-commit offline gate (unified):
- runs: powershell -File tools/run_checks_offline.ps1 -NoGitGuard
- blocks commit on non-zero exit code
- bypass: ESTER_PRECOMMIT_BYPASS=1 or git commit --no-verify
"""
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path
from typing import List, Tuple


ROOT = Path(__file__).resolve().parents[1]


def _env_base() -> dict:
    env = dict(os.environ)
    env["PYTHONDONTWRITEBYTECODE"] = "1"
    env.setdefault("ESTER_ALLOW_OUTBOUND_NETWORK", "0")
    env.setdefault("PYTHONIOENCODING", "utf-8")
    return env


def _powershell_candidates() -> List[str]:
    """
    Return candidate executables for PowerShell.
    Order:
    1) ESTER_POWERSHELL_EXE override
    2) Windows PowerShell: powershell
    3) PowerShell 7+: pwsh
    """
    override = (os.getenv("ESTER_POWERSHELL_EXE") or "").strip()
    if override:
        return [override]
    return ["powershell", "pwsh"]


def _run(cmd: List[str]) -> Tuple[int, str]:
    try:
        p = subprocess.run(
            cmd,
            cwd=str(ROOT),
            env=_env_base(),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            encoding="utf-8",
            errors="replace",
            check=False,
        )
        return int(p.returncode), p.stdout
    except FileNotFoundError:
        return 127, f"[pre-commit] executable not found: {cmd[0]}\n"


def main() -> int:
    bypass = str(os.getenv("ESTER_PRECOMMIT_BYPASS", "")).strip().lower()
    if bypass in {"1", "true", "yes", "on"}:
        print("[pre-commit] BYPASS enabled via ESTER_PRECOMMIT_BYPASS=1")
        return 0

    last_not_found = []
    for exe in _powershell_candidates():
        cmd = [
            exe,
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "tools/run_checks_offline.ps1",
            "-NoGitGuard",
            "-Quiet",
        ]
        rc, out = _run(cmd)
        if out:
            sys.stdout.write(out if out.endswith("\n") else (out + "\n"))
        if rc == 127:
            last_not_found.append(exe)
            continue
        if rc != 0:
            print("\n[pre-commit] BLOCKED: offline checks failed.")
            print("[pre-commit] Fix issues and retry commit.")
            print("[pre-commit] Emergency bypass (not recommended):")
            print("  - git commit --no-verify")
            print("  - or set ESTER_PRECOMMIT_BYPASS=1")
            print("[pre-commit] If PowerShell is missing, set ESTER_POWERSHELL_EXE=pwsh (or full path).")
            return 1
        return 0

    if last_not_found:
        print("[pre-commit] ERROR: PowerShell not found (tried: {}).".format(", ".join(last_not_found)))
        print("[pre-commit] Install PowerShell or set ESTER_POWERSHELL_EXE to a valid executable.")
        print("[pre-commit] Emergency bypass:")
        print("  - git commit --no-verify")
        print("  - or set ESTER_PRECOMMIT_BYPASS=1")
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
