# packaging/systemd/ester-lan-discovery.service
# Unit LAN discovery agent.

[Unit]
Description=Ester LAN Discovery Agent
After=network.target

[Service]
Type=simple
EnvironmentFile=/etc/default/ester-lan-discovery
ExecStart=/usr/bin/env python3 -m listeners.lan_discovery_agent
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=multi-user.target
