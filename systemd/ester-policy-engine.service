[Unit]
Description=Ester Security Policy Engine
After=network.target ester-events.service

[Service]
Type=simple
Environment=LOG_LEVEL=INFO
Environment=SECURITY_POLICIES_PATH=%h/ester/rules/security_policies.yaml
Environment=ESTER_EVENTS_FEED_URL=http://127.0.0.1:5000/events/feed
Environment=ESTER_EVENTS_POST_URL=http://127.0.0.1:5000/events/publish
WorkingDirectory=%h/ester
ExecStart=%h/ester/.venv/bin/python -m modules.security.policy_engine
Restart=on-failure
RestartSec=2

NoNewPrivileges=true
PrivateTmp=true
ProtectHome=yes
ProtectSystem=full
LockPersonality=true
MemoryDenyWriteExecute=true

[Install]
WantedBy=multi-user.target
