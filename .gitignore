# Default deny posture: allow only explicitly listed release files and trees.
/*

# Root metadata and legal documents
!/.gitignore
!/.gitattributes
!/.editorconfig
!/LICENSE
!/NOTICE
!/README.md
!/SECURITY.md
!/CONTRIBUTING.md
!/CODE_OF_CONDUCT.md
!/CHANGELOG.md
!/CITATION.cff
!/AUTHORS.md
!/TRADEMARK.md

# Documentation allowlist
!/docs/
/docs/*
!/docs/README.md
!/docs/QUICKSTART.md
!/docs/ARCHITECTURE.md
!/docs/L4W_ALIGNMENT.md
!/docs/THREAT_MODEL.md
!/docs/RELEASE_CHECKLIST.md

# Tooling allowlist
!/tools/
/tools/*
!/tools/scan_repo.ps1

# Branding assets
!/logo/
!/logo/**

# Public source targets
!/ESTER/
!/ESTER/**
!/modules/
!/modules/**

# Runtime/state exclusions (including inside allowed trees)
data/
state/
logs/
memory/
passport/
scroll/
chroma/
chromadb/
dumps/
manifests/
outbox/
out_reembed/
_ESTER_DUMP/
_tmp_corefacts_home/
artifacts/
private/

# Local secrets and environment
.env
.env.*
secrets/
*.pem
*.key
*.p12
*.pfx

# Build caches and binary/runtime artifacts
__pycache__/
*.py[cod]
*.so
*.dll
*.db
*.sqlite
*.sqlite3
*.jsonl
*.log
*.pid
