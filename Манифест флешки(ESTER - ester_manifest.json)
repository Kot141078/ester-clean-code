      "apply_once": true,
      "window_s": 3600                               // bezopasnoe okno ot mtime manifesta
    }
  }
}
{
  "deploy": {
    "enable": true,
    "mode": "dir|zip",
    "path": "deploy/app" | "deploy/app.zip",
    "version": "1.2.3",
    "target": "ester-1.2.3",
    "apply_once": true,
    "window": { "from": 1690000000, "to": 1990000000 }
  }
}
