{
  "version": 1,
  "items": [
    {"kind": "dump", "path": "backup/settings_backup.json"}
  ],
  "auto": {
    "settings": { "mode": "merge", "apply_once": true }
  }
}
{
  "auto": {
    "deploy": {
      "version": "2025.09.29-r1",
      "path": "portable/app",                        // koren reliza (otnositelno ESTER/)
