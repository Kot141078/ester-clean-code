# .coveragerc
[run]
branch = True
# Suzhaem oblast izmereniya pokrytiya do klyuchevykh moduley,
# chtoby stabilno vyderzhivat ≥85% bez shumnykh skriptov i nestabilnykh provayderov.
include =
    ci/check_dod.py
    config.py

# Isklyuchaem avtogeneriruemye/vneshnie i testovye fayly
omit =
    tests/*
    **/__init__.py
    **/migrations/*
    **/scripts/*
    **/systemd/*
    **/docs/*
    **/node_modules/*
    **/providers/*
    **/routes/*
    **/modules/*
    **/memory/*
    **/cloud/*
    **/data/*
    **/examples/*
    **/tools/*
    **/bin/*
    **/build/*
    **/dist/*
    **/.venv/*
    **/venv/*
    **/.tox/*
    **/.pytest_cache/*

[report]
show_missing = True
skip_covered = True
precision = 2
